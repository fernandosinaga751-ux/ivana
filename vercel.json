{
  "version": 2,
  "builds": [
    { "src": "**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/car-avanza\\.jpeg", "dest": "/car-avanza.jpeg" },
    { "src": "/car-innova\\.jpeg", "dest": "/car-innova.jpeg" },
    { "src": "/car-hiace\\.jpeg",  "dest": "/car-hiace.jpeg"  },
    { "src": "/logo\\.png",        "dest": "/logo.png"        },
    { "src": "/(.*)",              "dest": "/index.html"      }
  ]
}
